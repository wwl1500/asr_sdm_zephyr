config ASR_USR_LED
	bool "ASR user LED driver (GPIO / PWM)"
	default y
	depends on GPIO
	help
	  Driver for the onboard user LED (GP25 on XIAO RP2350).
	  Uses PWM brightness via pwm-leds when available, otherwise GPIO via gpio-leds.

config ASR_RGB_LED
	bool "ASR WS2812 RGB LED driver"
	default n
	depends on LED_STRIP
	help
	  Driver for the onboard WS2812 NeoPixel RGB LED on XIAO RP2350 (GP22, PIO0).

config ASR_LED_THREAD
	bool "ASR LED background thread"
	default n
	depends on ASR_USR_LED && ASR_RGB_LED
	help
	  Background thread: user LED steady on, RGB LED blinks blue.

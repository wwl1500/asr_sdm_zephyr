config ASR_AHRS
	bool "ASR AHRS fusion"
	default y
	depends on ASR_IMU
	help
	  AHRS fusion helpers built on top of the Fusion algorithm library.

config ASR_AHRS_THREAD
	bool "AHRS background thread"
	default n
	depends on ASR_AHRS
	help
	  Spawns a background thread that periodically reads cached IMU values and
	  updates AHRS outputs.

config ASR_AHRS_STARTUP_DELAY_MS
	int "AHRS thread startup delay in milliseconds"
	default 600
	depends on ASR_AHRS_THREAD
	help
	  Delay before starting periodic AHRS updates.

config ASR_AHRS_PERIOD_MS
	int "AHRS update period in milliseconds"
	default 1000
	depends on ASR_AHRS
	help
	  Delay between AHRS update iterations.

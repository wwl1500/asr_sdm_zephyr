config ASR_IMU
	bool "ASR IMU driver"
	default y
	depends on SENSOR
	help
	  Driver helpers for the project's ICM-42688 sensor. Provides device
	  readiness validation and single-sample reads.

config ASR_IMU_THREAD
	bool "IMU read/print background thread"
	default n
	depends on ASR_IMU
	help
	  Spawns a background thread that periodically reads and logs IMU samples.
	  Thread timing is configured with the options below.

config ASR_IMU_STARTUP_DELAY_MS
	int "IMU thread startup delay in milliseconds"
	default 500
	depends on ASR_IMU_THREAD
	help
	  Delay before validating the IMU device and creating the IMU logging
	  thread.

config ASR_IMU_PERIOD_MS
	int "IMU sampling period in milliseconds"
	default 1000
	depends on ASR_IMU_THREAD
	help
	  Delay between successful IMU fetch/log iterations.

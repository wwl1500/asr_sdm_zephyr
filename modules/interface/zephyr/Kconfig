config ASR_USB_INTERFACE
	bool "ASR USB CDC ACM interface"
	default n
	depends on SERIAL && UART_LINE_CTRL
	help
	  Raw USB CDC ACM data pipe. Provides interrupt-driven RX with a
	  background thread that delivers received buffers to a registered
	  callback, and blocking poll-out TX.

config ASR_USB_INTERFACE_THREAD_STACK_SIZE
	int "USB interface thread stack size"
	default 2048
	depends on ASR_USB_INTERFACE
	help
	  Stack size for the USB interface RX processing thread.

config ASR_USB_INTERFACE_THREAD_PRIORITY
	int "USB interface thread priority"
	default 1
	depends on ASR_USB_INTERFACE
	help
	  Priority of the USB interface RX processing thread.

config ASR_USB_INTERFACE_RX_BUF_SIZE
	int "USB interface RX buffer size"
	default 256
	depends on ASR_USB_INTERFACE
	help
	  Maximum number of bytes per received chunk delivered to the RX
	  callback.
